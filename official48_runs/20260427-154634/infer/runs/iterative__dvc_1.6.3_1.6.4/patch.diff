+def _get_experiment_revisions(repo, baseline_revs):
+    """Get experiment revisions for the given baseline revisions.
+
+    Args:
+        repo: The DVC repo instance.
+        baseline_revs: List of baseline revision identifiers (e.g., 'HEAD', 'v0')
+
+    Returns:
+        List of experiment revision SHAs derived from the baseline revisions.
+    """
+    import re
+
+    EXP_RE = re.compile(r"(?P<rev_sha>[a-f0-9]{7})-(?P<exp_sha>[a-f0-9]+)")
+
+    experiment_revs = []
+    for baseline_rev in baseline_revs:
+        # Get the full SHA of the baseline revision
+        try:
+            baseline_sha = repo.scm.resolve_rev(baseline_rev)
+        except Exception:
+            continue
+
+        # Look for experiment branches that match the baseline
+        for exp_branch in repo.experiments.scm.list_branches():
+            m = re.match(EXP_RE, exp_branch)
+            if m:
+                rev_sha = repo.scm.resolve_rev(m.group("rev_sha"))
+                if rev_sha == baseline_sha or rev_sha.startswith(baseline_sha):
+                    try:
+                        exp_rev = repo.experiments.scm.resolve_rev(exp_branch)
+                        experiment_revs.append(exp_rev)
+                    except Exception:
+                        continue
+
+    return experiment_revs if experiment_revs else baseline_revs

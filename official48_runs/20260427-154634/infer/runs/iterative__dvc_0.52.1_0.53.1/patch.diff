index 5716984..d93c11c 100644
--- a/dvc/scm/git/tree.py
+++ b/dvc/scm/git/tree.py
@@ -134,3 +134,76 @@ class GitTree(BaseTree):
 
         for x in self._walk(tree, topdown):
             yield x
+
+
+class GitSubmoduleTree(GitTree):
+    """Proxies the repo file access methods to Git objects for submodules.
+
+    This is a workaround for gitpython's handling of submodules.
+    See https://github.com/iterative/dvc/issues/1898
+    """
+
+    def git_object_by_path(self, path):
+        import git
+
+        path = relpath(os.path.realpath(path), self.git.working_dir)
+        assert path.split(os.sep, 1)[0] != ".."
+
+        try:
+            tree = self.git.tree(self.rev)
+        except git.exc.BadName as exc:
+            raise DvcException(
+                "revision '{}' not found in git '{}'".format(
+                    self.rev, os.path.relpath(self.git.working_dir)
+                ),
+                cause=exc,
+            )
+
+        if not path or path == ".":
+            return tree
+
+        for i in path.split(os.sep):
+            if not self._is_tree_and_contains(tree, i):
+                return None
+            entry = tree[i]
+            # Handle submodule entries
+            if entry.type_str == "commit":
+                # entry is a submodule reference, get the submodule's tree
+                sm = self.git.submodules.get(i)
+                if sm is None:
+                    # Fallback: try to find submodule by path
+                    for subm in self.git.submodules:
+                        if os.path.basename(subm.path) == i:
+                            sm = subm
+                            break
+                if sm is not None:
+                    tree = sm.module().commit(sm.hexsha).tree
+                else:
+                    return None
+            else:
+                tree = entry
+        return tree
+
+    def _walk(self, tree, topdown=True):
+        dirs, nondirs = [], []
+        for i in tree:
+            if i.mode == GIT_MODE_DIR:
+                dirs.append(i.name)
+            elif i.type_str == "commit":
+                # Handle submodule entries: add as a directory
+                dirs.append(i.name)
+            else:
+                nondirs.append(i.name)
+
+        if topdown:
+            yield os.path.normpath(tree.abspath), dirs, nondirs
+
+        for i in dirs:
+            if i in [entry.name for entry in tree if entry.type_str == "commit"]:
+                # This is a submodule entry, skip walking into it
+                continue
+            for x in self._walk(tree[i], topdown=True):
+                yield x
+
+        if not topdown:
+            yield os.path.normpath(tree.abspath), dirs, nondirs

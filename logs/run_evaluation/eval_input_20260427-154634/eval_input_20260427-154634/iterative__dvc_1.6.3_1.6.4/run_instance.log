+        *args,
+        revs=_revisions(revs, repo.scm.is_dirty(), experiment=experiment),
+        **kwargs,
     )
+
+
+def _get_experiment_revisions(repo, baseline_revs):
+    """Get experiment revisions for the given baseline revisions.
+
+    Args:
+        repo: The DVC repo instance.
+        baseline_revs: List of baseline revision identifiers (e.g., 'HEAD', 'v0')
+
+    Returns:
+        List of experiment revision SHAs derived from the baseline revisions.
+    """
+    import re
+
+    EXP_RE = re.compile(r"(?P<rev_sha>[a-f0-9]{7})-(?P<exp_sha>[a-f0-9]+)")
+
+    experiment_revs = []
+    for baseline_rev in baseline_revs:
+        # Get the full SHA of the baseline revision
+        try:
+            baseline_sha = repo.scm.resolve_rev(baseline_rev)
+        except Exception:
+            continue
+
+        # Look for experiment branches that match the baseline
+        for exp_branch in repo.experiments.scm.list_branches():
+            m = re.match(EXP_RE, exp_branch)
+            if m:
+                rev_sha = repo.scm.resolve_rev(m.group("rev_sha"))
+                if rev_sha == baseline_sha or rev_sha.startswith(baseline_sha):
+                    try:
+                        exp_rev = repo.experiments.scm.resolve_rev(exp_branch)
+                        experiment_revs.append(exp_rev)
+                    except Exception:
+                        continue
+
+    return experiment_revs if experiment_revs else baseline_revs
diff --git a/tests/func/experiments/test_experiments.py b/tests/func/experiments/test_experiments.py
index 52330df0a..7ebf71a3f 100644
--- a/tests/func/experiments/test_experiments.py
+++ b/tests/func/experiments/test_experiments.py
@@ -76,3 +76,27 @@ def test_checkout(tmp_dir, scm, dvc):
     dvc.experiments.checkout(exp_b)
     assert (tmp_dir / "params.yaml").read_text().strip() == "foo: 3"
     assert (tmp_dir / "metrics.yaml").read_text().strip() == "foo: 3"
+
+
+def test_get_baseline(tmp_dir, scm, dvc):
+    tmp_dir.gen("copy.py", COPY_SCRIPT)
+    tmp_dir.gen("params.yaml", "foo: 1")
+    stage = dvc.run(
+        cmd="python copy.py params.yaml metrics.yaml",
+        metrics_no_cache=["metrics.yaml"],
+        params=["foo"],
+        name="copy-file",
+    )
+    scm.add(["dvc.yaml", "dvc.lock", "copy.py", "params.yaml", "metrics.yaml"])
+    scm.commit("init")
+    expected = scm.get_rev()
+    assert dvc.experiments.get_baseline(expected) is None
+
+    dvc.reproduce(stage.addressing, experiment=True, params=["foo=2"])
+    rev = dvc.experiments.scm.get_rev()
+    assert dvc.experiments.get_baseline(rev) == expected
+
+    dvc.reproduce(
+        stage.addressing, experiment=True, params=["foo=3"], queue=True
+    )
+    assert dvc.experiments.get_baseline("stash@{0}") == expected

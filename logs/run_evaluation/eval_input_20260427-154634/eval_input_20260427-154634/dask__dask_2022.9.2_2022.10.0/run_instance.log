+def is_categorical_dtype(obj):
+    """Check if obj is a categorical dtype, compatible with pandas 2.x."""
+    dtype = getattr(obj, "dtype", obj)
+    return isinstance(dtype, pd.CategoricalDtype)
+
+
+def is_any_real_numeric_dtype(obj):
+    """Check if obj is a real numeric dtype (int/float), compatible with pandas 2.x."""
+    # In pandas 2.x, Index.is_numeric() is deprecated in favor of this function
+    # which was added in pandas 1.2.0
+    return pd.api.types.is_any_real_numeric_dtype(obj)
+
+
+def is_datetime64tz_dtype(obj):
+    """Check if obj is a datetime64 with timezone dtype, compatible with pandas 2.x."""
+    dtype = getattr(obj, "dtype", obj)
+    return isinstance(dtype, pd.DatetimeTZDtype)
+
+
+def is_period_dtype(obj):
+    """Check if obj is a period dtype, compatible with pandas 2.x."""
+    dtype = getattr(obj, "dtype", obj)
+    return isinstance(dtype, pd.PeriodDtype)
+
+
+def is_interval_dtype(obj):
+    """Check if obj is an interval dtype, compatible with pandas 2.x."""
+    dtype = getattr(obj, "dtype", obj)
+    return isinstance(dtype, pd.IntervalDtype)
+
+
+def is_sparse(obj):
+    """Check if obj is a sparse dtype, compatible with pandas 2.x."""
+    dtype = getattr(obj, "dtype", obj)
+    return isinstance(dtype, pd.SparseDtype)
+
+

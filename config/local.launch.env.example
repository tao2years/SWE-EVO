# Copy this file to config/local.launch.env and edit the values you need.

# Python interpreter. Leave empty to prefer .venv/bin/python3 automatically.
PYTHON_BIN=

# Dashboard
DASHBOARD_MODE=start
DASHBOARD_BACKGROUND=1
DASHBOARD_SESSION_NAME=subset-run-dashboard

# Run pipeline
RUN_BACKGROUND=1
RUN_SESSION_NAME=subset-innercc-run
RUN_CLI=innercc
RUN_MODE=direct
RUN_MANIFEST=config/subsets/project-coverage-7.txt
RUN_MODEL=
RUN_LIMIT=
RUN_MAX_TURNS=
RUN_INFER_MAX_CONCURRENCY=3
RUN_EVAL_MAX_CONCURRENCY=3
RUN_CLI_TIMEOUT_SECONDS=5400
RUN_CLI_BIN=
RUN_ENV_FILE=
RUN_SETTINGS_FILE=
RUN_ROUTER_ROOT=
RUN_ROUTER_API_BASE=
RUN_RESUME=0
RUN_NO_FORCE_WORKSPACE=0
